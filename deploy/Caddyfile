mcp.markroberts.io {
	# Help users who configure the connector with the bare domain — the actual
	# MCP transport lives at /mcp (no trailing slash; that's the canonical
	# FastMCP path, and Anthropic's connector validator does NOT follow
	# redirects on the protocol endpoint, so we must point at the exact path).
	redir / /mcp permanent

	# Generous timeouts: a full refresh can take 10+ minutes on first pull.
	reverse_proxy 127.0.0.1:8765 {
		transport http {
			read_timeout 30m
			write_timeout 30m
			dial_timeout 10s
		}
	}

	encode gzip

	log {
		output file /var/log/caddy/mcp.markroberts.io.log {
			roll_size 10mb
			roll_keep 10
		}
		format json
	}
}
